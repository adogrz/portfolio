---
import Icon from "@/components/Icon.astro";
import { profile } from "@/data/profile";
---

<div class="flex w-full min-w-0 flex-row items-center gap-2">
  <a
    class="flex min-h-11 min-w-0 flex-1 items-center truncate rounded-lg border border-(--border) bg-(--surface) px-3 py-1.5 text-sm text-(--brand) transition-colors hover:bg-(--surface-hover) sm:text-base"
    href={`mailto:${profile.email}`}
    aria-label={`Enviar correo a ${profile.name}`}
  >
    {profile.email}
  </a>
  <div class="flex shrink-0 items-center gap-2">
    <span class="contact-action">
      <a
        class="icon-button"
        href={`mailto:${profile.email}`}
        aria-label={`Enviar correo a ${profile.name}`}
        aria-describedby="send-email-tooltip"
      >
        <Icon name="send" class="h-5" />
      </a>
      <span class="contact-tooltip" id="send-email-tooltip" role="tooltip">
        Enviar correo
      </span>
    </span>
    <span class="contact-action">
      <button
        class="icon-button"
        type="button"
        data-copy-email={profile.email}
        data-copied="false"
        aria-label="Copiar dirección de correo"
        aria-describedby="copy-email-tooltip"
      >
        <span class="copy-icon relative size-5" aria-hidden="true">
          <Icon name="clipboard" class="copy-icon-default h-5" />
          <Icon
            name="copy-check"
            class="copy-icon-success absolute inset-0 h-5 text-(--brand)"
          />
        </span>
      </button>
      <span class="contact-tooltip" id="copy-email-tooltip" role="tooltip">
        Copiar correo
      </span>
    </span>
  </div>
</div>

<script>
  const copyButton =
    document.querySelector<HTMLButtonElement>("[data-copy-email]");
  let resetTimer: number | undefined;

  const setCopied = (copied: boolean) => {
    if (!copyButton) return;
    copyButton.dataset.copied = String(copied);
    copyButton.setAttribute(
      "aria-label",
      copied ? "Correo copiado" : "Copiar dirección de correo",
    );
  };

  copyButton?.addEventListener("click", async () => {
    if (resetTimer) clearTimeout(resetTimer);

    try {
      if (!navigator.clipboard || !copyButton.dataset.copyEmail)
        throw new Error();
      await navigator.clipboard.writeText(copyButton.dataset.copyEmail);
      setCopied(true);
      resetTimer = window.setTimeout(() => setCopied(false), 2500);
    } catch {
      setCopied(false);
    }
  });
</script>

<style>
  .contact-action {
    position: relative;
    display: inline-flex;
  }

  .contact-tooltip {
    position: absolute;
    bottom: calc(100% + 0.5rem);
    left: 50%;
    z-index: 20;
    width: max-content;
    max-width: min(10rem, calc(100vw - 2rem));
    padding: 0.25rem 0.375rem;
    border-radius: 0.375rem;
    color: var(--tooltip-foreground);
    background: var(--tooltip-background);
    box-shadow: 0 4px 10px rgb(15 23 42 / 0.18);
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1rem;
    text-align: center;
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, 0.25rem);
    transition:
      opacity 150ms ease,
      transform 150ms ease;
  }

  .contact-action:last-child .contact-tooltip {
    right: 0;
    left: auto;
    transform: translate(0, 0.25rem);
  }

  :global(.copy-icon-default),
  :global(.copy-icon-success) {
    transition:
      opacity 200ms ease,
      transform 200ms ease;
  }

  :global(.copy-icon-success),
  [data-copied="true"] :global(.copy-icon-default) {
    opacity: 0;
    transform: scale(0.75);
  }

  [data-copied="true"] :global(.copy-icon-success) {
    opacity: 1;
    transform: scale(1);
  }

  .contact-tooltip::before {
    position: absolute;
    bottom: -0.25rem;
    left: 50%;
    z-index: -1;
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 0.125rem;
    background: var(--tooltip-background);
    content: "";
    transform: translateX(-50%) rotate(45deg);
  }

  .contact-action:last-child .contact-tooltip::before {
    right: 1.1rem;
    left: auto;
    transform: rotate(45deg);
  }

  .contact-action:has([data-copied="true"]) .contact-tooltip {
    opacity: 0 !important;
    visibility: hidden;
    pointer-events: none;
  }

  .contact-action:has(:focus-visible):not(:has([data-copied="true"]))
    .contact-tooltip {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  .contact-action:last-child:has(:focus-visible):not(:has([data-copied="true"]))
    .contact-tooltip {
    transform: translate(0, 0);
  }

  @media (hover: hover) {
    .contact-action:not(:has([data-copied="true"])):hover .contact-tooltip {
      opacity: 1;
      transform: translate(-50%, 0);
    }

    .contact-action:last-child:not(:has([data-copied="true"])):hover
      .contact-tooltip {
      transform: translate(0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-tooltip,
    :global(.copy-icon-default),
    :global(.copy-icon-success) {
      transition: none;
    }
  }
</style>

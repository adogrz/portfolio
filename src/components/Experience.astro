---
import Icon from "@/components/Icon.astro";
import { experiences } from "@/data/experience";
---

<ol class="timeline relative">
  {
    experiences.map(({ date, title, company, description, link, current }) => (
      <li class="relative mb-10 pl-9 last:mb-0">
        <span class="timeline-marker absolute top-1.5 size-3 rounded-full border border-(--background) bg-(--muted)" />
        <div class="mb-3 flex flex-col items-start gap-2">
          <div class="flex flex-col items-start gap-2 sm:flex-row sm:items-center sm:gap-4">
            <h3 class="text-xl font-semibold text-balance text-(--brand)">
              {title}
            </h3>
            {current && (
              <span class="current-badge rounded-full border px-2.5 py-0.5 text-xs font-medium">
                Actualmente
              </span>
            )}
          </div>
          <p class="text-lg font-medium text-(--heading)">{company}</p>
        </div>
        <time class="mb-2 block text-sm leading-none text-(--muted)">
          {date}
        </time>
        <p class="mb-4 text-base font-normal text-pretty text-(--muted)">
          {description}
        </p>
        {link && (
          <a
            class="action-link w-fit"
            href={link}
            target="_blank"
            rel="noopener noreferrer"
          >
            Saber más
            <Icon name="arrow-right" class="h-5" />
          </a>
        )}
      </li>
    ))
  }
</ol>

<style>
  .timeline::before {
    position: absolute;
    top: 0.375rem;
    bottom: 0;
    left: 1rem;
    width: 2px;
    transform: translateX(-50%);
    background: var(--timeline);
    content: "";
  }

  .timeline-marker {
    left: 1rem;
    transform: translateX(-50%);
  }
</style>

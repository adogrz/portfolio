---
import { Image } from "astro:assets";

import Icon from "@/components/Icon.astro";
import { profile } from "@/data/profile";
---

<header
  class="header-shell sticky top-0 z-20 mx-auto flex h-20 max-w-3xl items-center justify-between px-6 backdrop-blur-lg"
>
  <div
    class="profile-summary flex min-w-0 items-center gap-2"
    data-profile-summary
    data-visible="false"
    aria-hidden="true"
  >
    <Image
      src={profile.portrait}
      alt=""
      width={48}
      height={48}
      loading="eager"
      class="size-12 shrink-0 rounded-full border-2 border-slate-300/70 object-cover shadow-sm dark:border-slate-700/70"
    />
    <span class="truncate text-lg font-semibold text-(--heading)">
      {profile.name}
    </span>
  </div>

  <button
    class="theme-toggle inline-flex size-11 shrink-0 cursor-pointer items-center justify-center rounded-md text-(--foreground) transition-colors hover:bg-(--surface-hover)"
    type="button"
    data-theme-toggle
    aria-label="Cambiar tema de color"
    aria-pressed="false"
  >
    <Icon name="sun" class="theme-icon theme-icon-light h-7" />
    <Icon name="moon" class="theme-icon theme-icon-dark h-7" />
  </button>
</header>

<script>
  const profileSummary = document.querySelector<HTMLElement>(
    "[data-profile-summary]",
  );
  const themeToggle = document.querySelector<HTMLButtonElement>(
    "[data-theme-toggle]",
  );
  const colorScheme = matchMedia("(prefers-color-scheme: dark)");

  const updateProfile = () => {
    if (profileSummary) {
      const isVisible = window.scrollY > 250;
      profileSummary.dataset.visible = String(isVisible);
      profileSummary.setAttribute("aria-hidden", String(!isVisible));
    }
  };

  const applyTheme = (theme: "light" | "dark") => {
    document.documentElement.dataset.theme = theme;
    document.documentElement.style.colorScheme = theme;
    document
      .querySelector('meta[name="theme-color"]')
      ?.setAttribute("content", theme === "dark" ? "#1D252C" : "#f3f7f9");
    if (themeToggle) {
      themeToggle.setAttribute("aria-pressed", String(theme === "dark"));
      themeToggle.setAttribute(
        "aria-label",
        theme === "dark" ? "Activar tema claro" : "Activar tema oscuro",
      );
    }
  };

  updateProfile();
  applyTheme(
    document.documentElement.dataset.theme === "dark" ? "dark" : "light",
  );
  addEventListener("scroll", updateProfile, { passive: true });

  themeToggle?.addEventListener("click", () => {
    const theme =
      document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    applyTheme(theme);
    try {
      localStorage.setItem("theme", theme);
    } catch {}
  });

  colorScheme.addEventListener("change", ({ matches }) => {
    try {
      if (localStorage.getItem("theme")) return;
    } catch {}
    applyTheme(matches ? "dark" : "light");
  });
</script>

<style>
  .header-shell {
    background: color-mix(in srgb, var(--background) 70%, transparent);
  }

  .profile-summary {
    opacity: 0;
    transform: translateY(-20px);
    transition:
      opacity 300ms ease,
      transform 300ms ease;
  }

  .profile-summary[data-visible="true"] {
    opacity: 1;
    transform: translateY(0);
  }

  :global(.theme-icon-dark),
  :global([data-theme="dark"] .theme-icon-light) {
    display: none;
  }

  :global([data-theme="dark"] .theme-icon-dark) {
    display: block;
  }
</style>

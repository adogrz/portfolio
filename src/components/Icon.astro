---
interface Props {
  name:
    | "arrow-right"
    | "arrow-up-right"
    | "briefcase"
    | "clipboard"
    | "copy-check"
    | "code"
    | "download"
    | "external-link"
    | "github"
    | "linkedin"
    | "link"
    | "mail"
    | "moon"
    | "send"
    | "star"
    | "sun";

---
import type { Technology } from "@/data/projects";

interface Props {
  technology: Technology;
  focusable?: boolean;
}

const { technology, focusable = true } = Astro.props;
const Logo = technology.logo;
---

<span
  class="technology-tag"
  role="img"
  tabindex={focusable ? "0" : undefined}
  aria-label={technology.name}
>
  <Logo class="technology-logo" aria-hidden="true" focusable="false" />
  <span class="technology-tooltip" aria-hidden="true">{technology.name}</span>
</span>

<style>
  .technology-tag {
    position: relative;
    display: inline-flex;
    width: 2rem;
    height: 2.5rem;
    align-items: center;
    justify-content: center;
    color: var(--foreground);
    cursor: default;
  }

  .technology-logo {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 1.625rem;
    max-height: 1.5rem;
    flex: none;
  }

  .technology-tooltip {
    position: absolute;
    bottom: calc(100% + 0.5rem);
    left: 50%;
    z-index: 20;
    width: max-content;
    max-width: min(10rem, calc(100vw - 2rem));
    padding: 0.25rem 0.375rem;
    border-radius: 0.375rem;
    color: var(--tooltip-foreground);
    background: var(--tooltip-background);
    box-shadow: 0 4px 10px rgb(15 23 42 / 0.18);
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1rem;
    text-align: center;
    overflow-wrap: anywhere;
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, 0.25rem);
    transition:
      opacity 150ms ease,
      transform 150ms ease;
  }

  .technology-tooltip::before {
    position: absolute;
    bottom: -0.25rem;
    left: 50%;
    z-index: -1;
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 0.125rem;
    background: var(--tooltip-background);
    content: "";
    transform: translateX(-50%) rotate(45deg);
  }

  .technology-tag:hover .technology-tooltip,
  .technology-tag:focus-visible .technology-tooltip {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .technology-tooltip {
      transition: none;
    }
  }
</style>

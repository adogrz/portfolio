---
import "@fontsource-variable/onest";
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import { profile } from "@/data/profile";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL("/social-preview.png", Astro.site);
const person = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  url: profile.urls.site,
  image: socialImage.href,
  jobTitle: profile.role,
  email: `mailto:${profile.email}`,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Santo Tomás",
    addressRegion: "San Salvador",
    addressCountry: "SV",
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "Universidad de El Salvador",
  },
  knowsAbout: [
    "Java",
    "Spring Boot",
    "APIs REST",
    "Docker",
    "Linux",
    "PostgreSQL",
    "Desarrollo web",
  ],
  sameAs: [profile.urls.github, profile.urls.linkedIn],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#f3f7f9" />
    <script is:inline>
      (() => {
        let storedTheme;
        try {
          storedTheme = localStorage.getItem("theme");
        } catch {}
        const theme =
          storedTheme === "light" || storedTheme === "dark"
            ? storedTheme
            : matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
        document
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute("content", theme === "dark" ? "#1D252C" : "#f3f7f9");
      })();
    </script>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <meta property="og:type" content="profile" />
    <meta property="og:locale" content="es_SV" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={profile.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content={`${profile.name}, ${profile.role}`}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta
      name="twitter:image:alt"
      content={`${profile.name}, ${profile.role}`}
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(person)}
    />
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <Header />
    <slot />
  </body>
</html>
